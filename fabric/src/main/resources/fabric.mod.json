{
  "schemaVersion": 1,
  "id": "ekotsk",
  "version": "${version}",
  "name": "Epic Knights of the Seven Kingdoms",
  "description": "An Epic Knights addon which adds various weapons, armor sets and remarkable items from the world of George Martin's 'A Song of Ice and Fire!'",
  "authors": [
    "Witchkings"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/ekotsk/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.ekotsk.fabric.ASOIAFModFabric"
    ],
    "client": [
      "net.ekotsk.fabric.client.ASOIAFModFabricClient"
    ]
  },
  "mixins": [
    "ekotsk.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.2",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "architectury": ">=9.2.14",
    "fabric-api": "*",
    "magistuarmory": ">=9.24"
  },
  "suggests": {
    "another-mod": "*"
  }
}
